{
  "name": "pi-agent-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "chat": "tsx src/index.ts",
    "demo": "tsx src/index.ts \"Please use the demo-journal-agent skill and recommend journals for a machine learning paper about efficient multimodal retrieval.\"",
    "check": "tsc --noEmit",
    "web:dev": "vite --config vite.config.ts",
    "web:build": "vite build --config vite.config.ts",
    "web:check": "tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@mariozechner/mini-lit": "^0.2.0",
    "@mariozechner/pi-agent-core": "0.66.1",
    "@mariozechner/pi-ai": "0.66.1",
    "@mariozechner/pi-coding-agent": "0.66.1",
    "@mariozechner/pi-web-ui": "0.66.1",
    "@sinclair/typebox": "^0.34.41",
    "lit": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.11"
  }
}
